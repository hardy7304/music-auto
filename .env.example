# =============================================================================
# 必看：預設使用 Playwright，不需要 LLM token；只有切回 browser-use / fallback 才需要 API 金鑰
# =============================================================================
#
# AUTOMATION_ENGINE=playwright  # playwright | browser_use | auto
# BROWSER_USE_FALLBACK=false    # true 時 Playwright 失敗會改用 browser-use（會消耗 LLM token）
#
# Playwright deterministic automation tuning
# PLAYWRIGHT_ACTION_TIMEOUT_SEC=12
# PLAYWRIGHT_GENERATION_WAIT_SEC=600
#
# 以下 LLM 金鑰只在 AUTOMATION_ENGINE=browser_use、AUTOMATION_ENGINE=auto、
# 或 BROWSER_USE_FALLBACK=true 時需要。
#
# 步驟 1）選供應商（不填 LLM_PROVIDER = 預設 google）
#   google      → 只填下面 GEMINI_API_KEY（Google AI Studio / Gemini API）
#   groq        → 設 LLM_PROVIDER=groq，並填 GROQ_API_KEY=
#   openrouter  → 設 LLM_PROVIDER=openrouter，並填 OPENROUTER_API_KEY=
#   auto        → Groq → OpenRouter（隨機）→ 本機 Ollama；需 GROQ_API_KEY + OPENROUTER_API_KEY（見 app/services/llm_manager.py）
#
# 步驟 2）模型 id 用 AGENT_MODEL（各供應商預設不同，見下方）
#
# 詳見 README「LLM 供應商」、docs/llm-providers-comparison.md
# =============================================================================

# google | groq | openrouter | auto（預設：google）
# LLM_PROVIDER=google

# --- 自動輪替（LLM_PROVIDER=auto）---
# LLM_PROVIDER=auto
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
# 預設僅用雲端（Groq→OpenRouter），不需本機 Ollama。若要本機 Ollama 作最後備援才設為 true：
# LLM_AUTO_USE_OLLAMA=false
# OLLAMA_MODEL=llama3.2
# OLLAMA_HOST=
# 每後端重試次數（預設 3）
# LLM_FAILOVER_MAX_RETRIES=3

# --- Google（LLM_PROVIDER=google 或未設定時；僅 browser-use / fallback 需要）---
# GEMINI_API_KEY=your_google_generative_language_api_key
# Agent LLM（Gemma / Gemini 模型 id，與 AI Studio 列表一致）
AGENT_MODEL=gemma-4-31b-it
# 範例：Gemma 26B 級 gemma-4-26b-a4b-it | Gemma 31B gemma-4-31b-it
#       Gemini：gemini-2.5-flash | gemini-2.5-flash-lite | gemini-2.5-pro | gemini-2.0-flash
# 若出現 429 RESOURCE_EXHAUSTED / free_tier_requests 用盡：隔日再試、升級配額、換專案金鑰，或改 AGENT_MODEL 為其他仍有額度的模型 id（見 README「Google API 配額」）
# Optional separate key when using Gemma; if unset, GEMINI_API_KEY is used
# GEMMA_API_KEY=

# --- Groq（LLM_PROVIDER=groq）---
# GROQ_API_KEY=
# AGENT_MODEL=llama-3.3-70b-versatile
# 其他範例：google/gemma2-9b-it（以 Groq 控制台顯示的 model id 為準）

# --- OpenRouter（LLM_PROVIDER=openrouter）---
# OPENROUTER_API_KEY=
# AGENT_MODEL=meta-llama/llama-3.3-70b-instruct
# 模型 slug 以 https://openrouter.ai/models 為準

# Chrome remote debugging (attach to your normal logged-in browser)
# Start Chrome like: chrome.exe --remote-debugging-port=9222
BROWSER_CDP_URL=http://127.0.0.1:9222

# --- Optional Notion (e.g. database 「perplixity 金曲設計」; share DB with integration) ---
# NOTION_TOKEN=secret_...
# NOTION_DATABASE_ID=   # 32-char hex; ?view=… is stripped automatically
#
# NOTION_TITLE_PROPERTY=歌名
# NOTION_PROP_LYRICS=歌詞
# NOTION_PROP_STYLE=Style / Tags
#
# Status column: use Notion native「狀態」type (option names must exist in DB)
# NOTION_PROP_STATUS_KIND=status
# NOTION_PROP_STATUS=創作階段
# NOTION_STATUS_VALUE_RUNNING=編曲中
# NOTION_STATUS_VALUE_DONE=完成
# NOTION_STATUS_VALUE_FAILED=草稿修改
#
# Legacy text column for status (instead of Status type):
# NOTION_PROP_STATUS_KIND=rich_text
#
# NOTION_PROP_SUCCESS=是否發佈
# NOTION_PROP_GENERATED_AT=AI生成時間
# NOTION_PROP_RESULT_URL=音樂連結
# NOTION_PROP_ERROR=錯誤訊息
# NOTION_PROP_NOTES=備註
# Select：與「純音樂」選項比對後走器樂填表（不填歌詞主欄）
# NOTION_PROP_VOCAL=人聲
# NOTION_INSTRUMENTAL_VOCAL_LABEL=純音樂
#
# 正式流程：python app/main.py --attach-open-page --from-notion --dry-run false
# （讀「是否發佈」未勾選列 → Mureka → 回寫同一筆）

MUREKA_BASE_URL=https://www.mureka.ai
# Used only when MUREKA_ATTACH_NAVIGATE_FIRST=true; set to the exact URL from your address bar
MUREKA_CREATE_URL=https://www.mureka.ai/tools/music-gen.html
# If true, navigate to MUREKA_CREATE_URL after CDP attach (default false avoids 404 on stale paths)
MUREKA_ATTACH_NAVIGATE_FIRST=false

# Create Music 頁：生成模型選擇（填表時由 Agent 依 UI 操作）。both=允許多選時同開 V9+O2；僅單選時會改選 O2
MUREKA_MODEL_MODE=both

# Notion 正式流程：同時併跑的分頁數（1=串行）。>1 請預先開同等數量 Mureka 分頁（見 README）
# NOTION_PARALLEL_MAX=1
# 安全測試用：只處理前 N 筆；0=不限制。第一次請用 1 搭配 DRY_RUN=true。
# NOTION_RUN_LIMIT=1

DRY_RUN=true

# ---------------------------------------------------------------------------
# Mureka Multi‑Asset Downloader settings (powered by MurekaDownloader service)
# ---------------------------------------------------------------------------
# Directory where downloaded files are stored (each song gets its own subfolder)
DOWNLOAD_DIR=../downloads
# Maximum concurrent download operations (1-10)
DOWNLOAD_MAX_PARALLEL=3
# Number of retry attempts for failed downloads (0-5)
DOWNLOAD_RETRY_COUNT=3
# Automatically download after successful song generation
AUTO_DOWNLOAD_AFTER_GENERATE=false

# Download profile — controls which assets are downloaded per song:
#   basic   = mp3 + commercial license (safe, fast)
#   archive = mp3 + wav + commercial license
#   full    = mp3 + wav + stems/midi + commercial license (large files!)
#   video   = mp3 + video + commercial license
#   custom  = use individual DOWNLOAD_* toggles below
DOWNLOAD_PROFILE=basic

# Individual asset toggles (mainly for custom profile; also override profile defaults)
DOWNLOAD_COMMERCIAL_LICENSE=true
DOWNLOAD_WAV=false
DOWNLOAD_STEMS_MIDI=false
DOWNLOAD_VIDEO=false

# Max individual file size in MB (0 = no limit). Warnings logged if exceeded.
DOWNLOAD_MAX_FILE_SIZE_MB=300

# If true, abort when login funnel (Try free now / Sign in / Continue with Google) is detected
REQUIRE_LOGGED_IN_PAGE=true

SCREENSHOTS_DIR=screenshots

HEADLESS=false

# --- Agent tuning（耗時／速度取捨，見 README「一首要多久」）---
# 單步逾時（秒）；調小＝較快失敗，調大＝較耐等
# AGENT_STEP_TIMEOUT=240
# 僅限 LLM 呼叫逾時（秒）；空＝不另設
# AGENT_LLM_TIMEOUT=
# 單次 Agent.run 步數上限
# AGENT_MAX_STEPS=120
# AGENT_WALL_CHECK_MAX_STEPS=10
# AGENT_VERIFY_CREATE_MAX_STEPS=15
# AGENT_FILL_MAX_STEPS=45
# AGENT_SUBMIT_MAX_STEPS=25
# 點 Generate 後「等畫面穩定」步數；太小易還沒生成完就 extract
# AGENT_SETTLE_MAX_STEPS=80
# AGENT_EXTRACT_MAX_STEPS=25
